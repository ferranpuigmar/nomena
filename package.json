{
  "name": "nomena-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "firebase:deploy:indexes": "cd .. && npx firebase-tools deploy --only firestore:indexes --project nomena-3177f",
    "seed:extract:names": "tsx src/features/seeds/scripts/extract-ine-names.ts",
    "seed:enrich:behindthename": "tsx --env-file=.env src/features/seeds/scripts/enrich-behindthename.ts",
    "seed:enrich:namedictionary": "tsx --env-file=.env src/features/seeds/scripts/enrich-behindthename.ts",
    "seed:enrich:web": "tsx src/features/seeds/scripts/enrich-names-web.ts",
    "seed:generate:json": "tsx src/features/seeds/scripts/generate-names-json.ts",
    "seed:upload": "GOOGLE_APPLICATION_CREDENTIALS=./service-account.json tsx src/features/seeds/scripts/upload-names-to-firebase.ts",
    "seed:clear:names": "GOOGLE_APPLICATION_CREDENTIALS=./service-account.json tsx src/features/seeds/scripts/clear-names.ts",
    "seed:migrate:users:display-name": "GOOGLE_APPLICATION_CREDENTIALS=./service-account.json tsx src/features/seeds/scripts/migrate-users-display-name.ts",
    "seed:generate:letters": "GOOGLE_APPLICATION_CREDENTIALS=./service-account.json tsx src/features/seeds/scripts/generateInitialLetters.ts",
    "seed:enrich:meaning": "tsx src/features/seeds/scripts/enrich-names-meaning.ts",
    "seed:migrate:origin-meaning": "GOOGLE_APPLICATION_CREDENTIALS=./service-account.json tsx src/features/seeds/scripts/migrate-names-origin-meaning.ts"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-query-devtools": "^5.99.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.12.0",
    "firebase-admin": "^13.8.0",
    "nanoid": "^5.1.9",
    "node-fetch": "^3.3.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.73.1",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.14.1",
    "tailwind-merge": "^3.5.0",
    "use-debounce": "^10.1.1",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.3",
    "@tanstack/eslint-plugin-query": "^5.99.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cheerio": "^1.2.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vite-plugin-svgr": "^5.2.0"
  }
}
